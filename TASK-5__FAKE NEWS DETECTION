//APP.PY
"""
app.py
------
Fake News Detection - Streamlit Web Application

This app lets a user paste a news article (or headline) into a text box
and get an instant prediction of whether it's likely REAL or FAKE news,
using the Logistic Regression model and TF-IDF vectorizer trained by
train.py and saved as model.pkl / vectorizer.pkl.

Run this app with:
    streamlit run app.py
"""

# ----------------------------------------------------------------------------
# 1. IMPORTS
# ----------------------------------------------------------------------------
import os
import re
import string
import pickle

import streamlit as st
import nltk
from nltk.corpus import stopwords


# ----------------------------------------------------------------------------
# 2. CONFIGURATION
# ----------------------------------------------------------------------------
MODEL_PATH = "model.pkl"
VECTORIZER_PATH = "vectorizer.pkl"


# ----------------------------------------------------------------------------
# 3. NLTK SETUP (cached so it only runs once per app session, not on every
#    user interaction / rerun, which keeps the app feeling fast)
# ----------------------------------------------------------------------------
@st.cache_resource
def setup_nltk():
    """
    Ensure required NLTK resources are downloaded, then return the
    English stopwords set for use in text cleaning.
    """
    resources = {
        "stopwords": "corpora/stopwords",
        "punkt": "tokenizers/punkt",
        "punkt_tab": "tokenizers/punkt_tab",
    }
    for resource_name, resource_path in resources.items():
        try:
            nltk.data.find(resource_path)
        except LookupError:
            nltk.download(resource_name, quiet=True)

    return set(stopwords.words("english"))


# ----------------------------------------------------------------------------
# 4. TEXT PREPROCESSING (must exactly mirror the cleaning logic used in
#    train.py, otherwise the model will see differently-formatted input
#    at prediction time than it learned from during training)
# ----------------------------------------------------------------------------
def clean_text(text: str, stop_words: set) -> str:
    """
    Apply the same preprocessing steps used during training:
    lowercase -> remove punctuation -> remove numbers -> tokenize -> remove stopwords.
    """
    if not isinstance(text, str):
        return ""

    text = text.lower()
    text = text.translate(str.maketrans(string.punctuation, " " * len(string.punctuation)))
    text = re.sub(r"\d+", " ", text)
    text = re.sub(r"\s+", " ", text).strip()

    tokens = nltk.word_tokenize(text)
    cleaned_tokens = [word for word in tokens if word not in stop_words and len(word) > 1]

    return " ".join(cleaned_tokens)


# ----------------------------------------------------------------------------
# 5. LOAD MODEL AND VECTORIZER (cached so the pickle files are only read
#    from disk once, not on every single button click)
# ----------------------------------------------------------------------------
@st.cache_resource
def load_artifacts(model_path: str, vectorizer_path: str):
    """
    Load the trained Logistic Regression model and the fitted TF-IDF
    vectorizer from their pickle files. Returns (model, vectorizer, error).
    If something goes wrong, error will contain a user-friendly message
    and model/vectorizer will be None.
    """
    if not os.path.exists(model_path) or not os.path.exists(vectorizer_path):
        error_msg = (
            "Model or vectorizer file not found.\n\n"
            f"Expected files:\n- {model_path}\n- {vectorizer_path}\n\n"
            "Please run 'python train.py' first to train the model and "
            "generate these files."
        )
        return None, None, error_msg

    try:
        with open(model_path, "rb") as model_file:
            model = pickle.load(model_file)
        with open(vectorizer_path, "rb") as vec_file:
            vectorizer = pickle.load(vec_file)
        return model, vectorizer, None
    except Exception as exc:
        return None, None, f"Failed to load model/vectorizer: {exc}"


# ----------------------------------------------------------------------------
# 6. PREDICTION LOGIC
# ----------------------------------------------------------------------------
def predict_news(text: str, model, vectorizer, stop_words: set):
    """
    Clean the input text, vectorize it with the loaded TF-IDF vectorizer,
    and return a (label, confidence) tuple where label is "FAKE" or "REAL"
    and confidence is the model's probability for that predicted class.
    """
    cleaned = clean_text(text, stop_words)

    if cleaned.strip() == "":
        return None, None  # nothing meaningful left after cleaning

    features = vectorizer.transform([cleaned])
    prediction = model.predict(features)[0]

    # predict_proba gives [P(class=0=REAL), P(class=1=FAKE)]
    probabilities = model.predict_proba(features)[0]
    confidence = probabilities[prediction]

    label = "FAKE" if prediction == 1 else "REAL"
    return label, confidence


# ----------------------------------------------------------------------------
# 7. STREAMLIT PAGE LAYOUT
# ----------------------------------------------------------------------------
def main():
    st.set_page_config(
        page_title="Fake News Detector",
        page_icon="📰",
        layout="centered",
    )

    st.title("📰 Fake News Detection")
    st.write(
        "Paste a news headline or article body below, and this app will "
        "predict whether it's likely **REAL** or **FAKE** news using a "
        "Logistic Regression model trained on TF-IDF features."
    )

    # ---- Load NLTK resources and model artifacts (cached) ----
    stop_words = setup_nltk()
    model, vectorizer, load_error = load_artifacts(MODEL_PATH, VECTORIZER_PATH)

    if load_error:
        st.error(load_error)
        st.stop()  # halt the app here; nothing else can run without the model

    # ---- Input area ----
    user_text = st.text_area(
        "Enter news text:",
        height=220,
        placeholder="Paste a news article or headline here...",
    )

    col1, col2 = st.columns([1, 3])
    with col1:
        predict_clicked = st.button("🔍 Predict", type="primary", use_container_width=True)
    with col2:
        st.caption("Tip: longer text (a full paragraph) usually gives more reliable predictions than a single short headline.")

    # ---- Handle prediction ----
    if predict_clicked:
        if not user_text or user_text.strip() == "":
            st.warning("⚠️ Please enter some news text before clicking Predict.")
        else:
            try:
                label, confidence = predict_news(user_text, model, vectorizer, stop_words)

                if label is None:
                    st.warning(
                        "⚠️ After cleaning, no meaningful words were left to analyze. "
                        "Please enter a longer or more descriptive piece of text."
                    )
                elif label == "FAKE":
                    st.error(f"🚨 Prediction: **FAKE NEWS** (confidence: {confidence:.1%})")
                else:
                    st.success(f"✅ Prediction: **REAL NEWS** (confidence: {confidence:.1%})")

                with st.expander("See cleaned text used for prediction"):
                    st.write(clean_text(user_text, stop_words))

            except Exception as exc:
                st.error(f"An error occurred while making the prediction: {exc}")

    # ---- Sidebar with extra info ----
    with st.sidebar:
        st.header("ℹ️ About")
        st.write(
            "This app uses:\n"
            "- **TF-IDF** for text feature extraction\n"
            "- **Logistic Regression** for classification\n\n"
            "Model trained on the Kaggle *Fake and Real News Dataset*."
        )
        st.warning(
            "This tool is for educational purposes only and should not be "
            "used as the sole basis for verifying real-world news."
        )


if __name__ == "__main__":
    main()



