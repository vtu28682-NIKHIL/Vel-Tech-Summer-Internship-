# ----------------------------
# RESUME ANALYSIS PROMPT TEMPLATE
# ----------------------------

SYSTEM_PROMPT = """You are ResumeIQ, an expert AI resume analyst and career coach with deep knowledge of:
- ATS (Applicant Tracking Systems) and how they score resumes
- Industry-specific hiring standards across tech, finance, marketing, healthcare, and more
- Resume writing best practices, formatting, and keyword optimization
- Career gap analysis and skill assessment
- Job market trends

RULES:
1. Answer ONLY using the resume content provided in the context.
2. Be specific — reference actual details from the resume (names, companies, skills, dates).
3. If information is not in the resume, say so clearly.
4. For scores, always explain the rating with concrete reasons.
5. Format your answers clearly with bullet points or sections when helpful.
6. Be constructive, professional, and actionable.

Resume Context:
{context}

Candidate's Question:
{question}

Your Analysis:"""

# ----------------------------
# USER INPUT & RESPONSE
# ----------------------------

clicked = st.session_state.get("clicked_query")
new_question = st.chat_input(
    "Ask about skills, ATS score, improvements, job fit…",
    key="resume_chat_input"
)

question = new_question or clicked
st.session_state.clicked_query = None

if question and question.strip():

    # Prevent duplicate runs
    if st.session_state.get("last_question") == question:
        st.stop()
    st.session_state.last_question = question

    st.session_state.messages.append({"role": "user", "content": question})

    with st.chat_message("user"):
        st.markdown(question)

    with st.chat_message("assistant"):

        if st.session_state.vectorstore is None:
            answer = (
                "⚠️  No resume loaded yet. Please upload a PDF resume using the "
                "sidebar and click **⚡ Analyze Resume(s)** first."
            )
            st.markdown(answer)

        else:
            with st.spinner("Analyzing resume…"):

                retriever = st.session_state.vectorstore.as_retriever(
                    search_type="mmr",
                    search_kwargs={"k": 8, "fetch_k": 25}
                )

                docs = retriever.invoke(question)

                context = ""
                pages_used = set()

                for doc in docs:
                    page = doc.metadata.get("page", "?")
                    source = doc.metadata.get("source_file", "resume")
                    pages_used.add(f"{source} – p.{page + 1 if isinstance(page, int) else page}")
                    context += f"\n--- [{source} | Page {page}] ---\n{doc.page_content}\n"

                prompt = SYSTEM_PROMPT.format(context=context, question=question)

                llm = get_llm()
                response = llm.invoke(prompt)
                answer = response.content

                if pages_used:
                    answer += f"\n\n---\n*Sources: {', '.join(sorted(pages_used))}*"

            st.markdown(answer)

        st.session_state.messages.append({"role": "assistant", "content": answer})
