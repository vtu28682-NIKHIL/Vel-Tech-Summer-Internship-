# ----------------------------
# HEADER
# ----------------------------

st.title("ResumeIQ")
st.markdown('<p class="subtitle">Upload a resume and ask anything — skills, gaps, ATS score, improvements, and more.</p>', unsafe_allow_html=True)

if not api_key:
    st.error("⚠️  GROQ_API_KEY not found in .env file. Add it and restart.")
    st.stop()

# ----------------------------
# EMBEDDING MODEL
# ----------------------------

@st.cache_resource
def load_embeddings():
    return HuggingFaceEmbeddings(model_name="sentence-transformers/all-MiniLM-L6-v2")

embeddings = load_embeddings()

# ----------------------------
# LLM
# ----------------------------

def get_llm():
    return ChatGroq(
        model="llama-3.3-70b-versatile",
        temperature=0.2,
        api_key=api_key
    )

# ----------------------------
# SESSION STATE
# ----------------------------

for key, default in {
    "clicked_query": None,
    "messages": [],
    "vectorstore": None,
    "resume_name": None,
    "last_question": None,
}.items():
    if key not in st.session_state:
        st.session_state[key] = default

# ----------------------------
# LOAD SAVED FAISS INDEX
# ----------------------------

if st.session_state.vectorstore is None and os.path.exists("resume_faiss_index"):
    try:
        st.session_state.vectorstore = FAISS.load_local(
            "resume_faiss_index",
            embeddings,
            allow_dangerous_deserialization=True
        )
        st.sidebar.success("✅ Loaded previously analyzed resume")
    except Exception:
        pass

# ----------------------------
# SIDEBAR
# ----------------------------

with st.sidebar:

    st.markdown("""
    <div style="text-align:center; padding:16px 0 8px 0;">
        <div style="font-size:36px;">📄</div>
        <div style="font-size:18px; font-weight:700; color:#e6edf3;">ResumeIQ</div>
        <div style="font-size:12px; color:#8b949e;">AI-Powered Resume Analyzer</div>
    </div>
    """, unsafe_allow_html=True)

    st.divider()

    # ── Upload section ──
    st.markdown('<p class="sidebar-label">📂 Upload Resume</p>', unsafe_allow_html=True)

    uploaded_files = st.file_uploader(
        "Upload PDF resume(s)",
        type="pdf",
        accept_multiple_files=True,
        label_visibility="collapsed"
    )

    pdf_count = len(uploaded_files) if uploaded_files else 0

    col1, col2 = st.columns(2)
    with col1:
        st.metric("📚 Resumes", pdf_count)

    if uploaded_files:
        st.markdown('<p class="sidebar-label" style="margin-top:8px;">Files</p>', unsafe_allow_html=True)
        for pdf in uploaded_files:
            st.write(f"📄 {pdf.name}")

    # ── Analyze button ──
    if st.button("⚡ Analyze Resume(s)", use_container_width=True):
        if not uploaded_files:
            st.warning("Please upload at least one PDF resume.")
            st.stop()

        documents = []
        progress = st.progress(0)

        with st.spinner("Reading resume(s)..."):
            for i, uploaded_file in enumerate(uploaded_files):
                with tempfile.NamedTemporaryFile(delete=False, suffix=".pdf") as tmp:
                    tmp.write(uploaded_file.read())
                    pdf_path = tmp.name

                loader = PyPDFLoader(pdf_path)
                docs = loader.load()
                # Tag each chunk with the filename
                for doc in docs:
                    doc.metadata["source_file"] = uploaded_file.name
                documents.extend(docs)
                progress.progress((i + 1) / len(uploaded_files))

        splitter = RecursiveCharacterTextSplitter(
            chunk_size=1500,
            chunk_overlap=200
        )
        chunks = splitter.split_documents(documents)

        with st.spinner("Building knowledge base..."):
            vectorstore = FAISS.from_documents(chunks, embeddings)
            vectorstore.save_local("resume_faiss_index")

        st.session_state.vectorstore = vectorstore
        st.session_state.resume_name = ", ".join(f.name for f in uploaded_files)
        st.session_state.messages = []   # fresh chat for new resume
        st.success(f"✅ Analyzed {len(uploaded_files)} resume(s)!")

    st.divider()

    # ── Recent searches ──
    st.markdown('<p class="sidebar-label">🕘 Recent Questions</p>', unsafe_allow_html=True)

    recent_queries = [
        msg["content"]
        for msg in st.session_state.messages
        if msg["role"] == "user"
    ]
    recent_queries = list(reversed(recent_queries))

    if recent_queries:
        for i, query in enumerate(recent_queries[:8]):
            display_text = query[:38] + "…" if len(query) > 38 else query
            if st.button(f"💬 {display_text}", key=f"rec_{i}"):
                st.session_state.clicked_query = query
    else:
        st.caption("No questions yet.")

    st.divider()

    # ── Reset ──
    if st.button("🗑️  Clear Chat", use_container_width=True):
        st.session_state.messages = []
        st.rerun()

